{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "sql:default",
    "sql:allow-execute",
    "sql:allow-load",
    "sql:allow-select",
    "sql:allow-close",
    "dialog:default",
    "fs:default",
    "shell:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "powershell",
          "cmd": "powershell",
          "args": ["-Command", "*"]
        },
        {
          "name": "cmd",
          "cmd": "cmd",
          "args": ["/C", "*"]
        },
        {
          "name": "git",
          "cmd": "git",
          "args": ["*"]
        }
      ]
    }
  ]
}